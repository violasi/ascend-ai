# === LLM Configuration ===
# API Key (required)
LLM_API_KEY=sk-xxx

# Base URL (optional, defaults to OpenAI)
# OpenAI:    https://api.openai.com/v1  (default, can omit)
# MiniMax:   https://api.minimax.chat/v1
# DeepSeek:  https://api.deepseek.com/v1
# Moonshot:  https://api.moonshot.cn/v1
# Together:  https://api.together.xyz/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model names (adjust to match your provider)
# OpenAI:    gpt-4o-mini / gpt-4o
# MiniMax:   MiniMax-Text-01
# DeepSeek:  deepseek-chat / deepseek-reasoner
# Moonshot:  moonshot-v1-8k
LLM_MODEL=gpt-4o-mini
LLM_MODEL_STRONG=gpt-4o

# === Database ===
DATABASE_URL=postgresql://jobprep:jobprep@localhost:5432/job_prep_dashboard
